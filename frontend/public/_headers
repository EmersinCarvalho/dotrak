# Headers de Performance e Segurança - Dotrak

# Cache para assets estáticos
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Cache para imagens
/img/*
  Cache-Control: public, max-age=31536000, immutable

# Headers de segurança
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://dotrak.com http://localhost:5000

# Cache para fontes
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
